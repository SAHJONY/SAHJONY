# Hermes Agent SaaS Backend Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Hermes Agent (optional - path to local hermes-agent for integration)
HERMES_AGENT_PATH=

# Twenty CRM Integration (optional)
TWENTY_API_URL=https://api.twenty.com/graphql
TWENTY_API_KEY=your-twenty-personal-access-token

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false