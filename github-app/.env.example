# Environment variables for SAHJONY GitHub App

# Server
PORT=3000
NODE_ENV=development

# GitHub App Configuration
GITHUB_APP_ID=your_app_id_here
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYour private key here\n-----END RSA PRIVATE KEY-----\n"
WEBHOOK_SECRET=your_webhook_secret_here

# SAHJONY Integration (optional - uses built-in analysis if not set)
SAHJONY_API_URL=https://api.sahjony.ai
SAHJONY_API_KEY=your_sahjony_api_key

# LLM Provider for enhanced analysis (optional)
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
GOOGLE_API_KEY=your_google_key

# Logging
LOG_LEVEL=info